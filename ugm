interactive_menu() {
    clear
    cat << EOF
==================================================
        USER/GROUP MANAGER (UGM) v1.9
==================================================
Usage: ugm.sh [OPTIONS]
Run 'ugm.sh --help' for full CLI usage.

Data & Logs Locations:
  Ledger DB:    ${LEDGER}
  Passwords:    ${PASS_DIR}
  Audit Log:    ${AUDIT_LOG}
  Backups:      ${BACKUP_DIR}

 --- USER MANAGEMENT ---
 [1] Provision New User (Interactive)
 [2] Safe Delete / Offboard User
 [3] FORCE LOGOUT User (Panic Button)
 [4] List Active Users
 --- GROUP MANAGEMENT ---
 [5] Create Group
 [6] Delete Group (Interactive Migration)
 [7] List Active Groups
 --- REPORTING & AUDIT ---
 [8] Check User Resource Usage (Snapshot)
 --- BULK & MAINTENANCE ---
 [9] Bulk Import from CSV
 [10] Dry-Run Bulk Import from CSV
 [11] Shred Temporary Passwords
 [12] Exit
==================================================
EOF
    read -r -p "Select option(s) (comma-separated, e.g., 1 or 4,7): " opt_str < /dev/tty

    IFS=',' read -ra OPTS <<< "$opt_str"
    for opt in "${OPTS[@]}"; do
        opt=$(echo "$opt" | xargs) # trim whitespace
        echo -e "\n${CYAN}--- Executing Option [$opt] ---${NC}"
        case $opt in
            1) cmd_create_user ;;
            2) cmd_delete_user ;;
            3) cmd_panic_kick ;;
            4) cmd_list_users ;;
            5) cmd_group_create ;;
            6) cmd_group_delete ;;
            7) cmd_list_groups ;;
            8) cmd_resources ;;
            9)
                echo -e "${CYAN}=== CSV Format Requirements ===${NC}"
                echo "Expected Columns : username,password,uid,gid,groups,shell"
                echo " - password      : Use 'auto' to auto-generate securely."
                echo " - uid/gid       : Numeric values (Protected IDs strictly blocked)."
                echo " - groups        : Comma-separated (e.g., sudo,docker) or 'none'."
                echo " - shell         : Must exist in /etc/shells (e.g., /bin/bash)."
                echo "======================================="
                read -r -p "Enter path to CSV file: " csv_file < /dev/tty
                read -r -p "Allow system IDs (uid/gid < min)? [y/N]: " allow_sys_in < /dev/tty
                local allow_sys="false"
                if [[ "${allow_sys_in:-N}" =~ ^[Yy] ]]; then allow_sys="true"; fi
                cmd_bulk_import "$csv_file" "false" "$allow_sys"
                ;;
            10)
                echo -e "${CYAN}=== CSV Format Requirements ===${NC}"
                echo "Expected Columns : username,password,uid,gid,groups,shell"
                echo " - password      : Use 'auto' to auto-generate securely."
                echo " - uid/gid       : Numeric values (Protected IDs strictly blocked)."
                echo " - groups        : Comma-separated (e.g., sudo,docker) or 'none'."
                echo " - shell         : Must exist in /etc/shells (e.g., /bin/bash)."
                echo "======================================="
                read -r -p "Enter path to CSV file: " csv_file < /dev/tty
                read -r -p "Allow system IDs (uid/gid < min)? [y/N]: " allow_sys_in < /dev/tty
                local allow_sys="false"
                if [[ "${allow_sys_in:-N}" =~ ^[Yy] ]]; then allow_sys="true"; fi
                cmd_bulk_import "$csv_file" "true" "$allow_sys"
                ;;
            11)
                echo "Removing all temporary password files from ${PASS_DIR}..."
                find "${PASS_DIR}" -type f -name "*_temp_pass.txt" -exec rm -f {} \;
                echo "Done."
                ;;
            12) exit 0 ;;
            *) echo -e "${RED}Invalid option: $opt${NC}" ;;
        esac
    done
}

if [[ $# -eq 0 ]]; then
    interactive_menu
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--create)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a username." >&2; exit 1; fi
            cmd_create_user "$2"
            shift 2
            ;;
        -d|--delete)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a username." >&2; exit 1; fi
            cmd_delete_user "$2"
            shift 2
            ;;
        -k|--kick)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a username." >&2; exit 1; fi
            cmd_panic_kick "$2"
            shift 2
            ;;
        -R|--resources)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a username." >&2; exit 1; fi
            cmd_resources "$2"
            shift 2
            ;;
        -lu|--list-users)
            cmd_list_users
            shift 1
            ;;
        -gc|--group-create)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a group name." >&2; exit 1; fi
            cmd_group_create "$2"
            shift 2
            ;;
        -gd|--group-delete)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a group name." >&2; exit 1; fi
            target_group="$2"
            migrate_to=""
            shift 2
            if [[ $# -gt 0 && ("$1" == "--migrate-to" || "$1" == "-m") ]]; then
                if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a group name." >&2; exit 1; fi
                migrate_to="$2"
                shift 2
            fi
            cmd_group_delete "$target_group" "$migrate_to"
            ;;
        -lg|--list-groups)
            cmd_list_groups
            shift 1
            ;;
        -b|--bulk)
            if [[ -z "${2:-}" ]]; then echo "Error: $1 requires a CSV file path." >&2; exit 1; fi
            csv_file="$2"
            shift 2
            is_dry_run="false"
            allow_sys="false"
            while [[ $# -gt 0 ]]; do
                if [[ "$1" == "--dry-run" || "$1" == "-n" ]]; then
                    is_dry_run="true"
                    shift 1
                elif [[ "$1" == "--allow-system-ids" || "$1" == "-a" ]]; then
                    allow_sys="true"
                    shift 1
                else
                    break
                fi
            done
            cmd_bulk_import "$csv_file" "$is_dry_run" "$allow_sys"
            ;;
        -n|--dry-run|-a|--allow-system-ids)
            echo -e "${RED}Error: $1 must follow --bulk <file.csv>${NC}" >&2
            exit 1
            ;;
        -s|--shred-passwords)
            echo "Removing all temporary password files from ${PASS_DIR}..."
            find "${PASS_DIR}" -type f -name "*_temp_pass.txt" -exec rm -f {} \;
            echo "Done."
            shift 1
            ;;
        -i|--install-completion)
            mkdir -p /etc/bash_completion.d
            cat << 'EOF' > /etc/bash_completion.d/ugm
_ugm_completions() {
    local cur prev opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    opts="-c --create -d --delete -k --kick -R --resources -lu --list-users -gc --group-create -gd --group-delete -m --migrate-to -lg --list-groups -b --bulk -n --dry-run -a --allow-system-ids -s --shred-passwords -i --install-completion -h --help"

    case "${prev}" in
        -c|--create|-d|--delete|-k|--kick|-R|--resources)
            COMPREPLY=( $(compgen -u -- ${cur}) )
            return 0
            ;;
        -gc|--group-create|-gd|--group-delete|-m|--migrate-to)
            COMPREPLY=( $(compgen -g -- ${cur}) )
            return 0
            ;;
        -b|--bulk)
            COMPREPLY=( $(compgen -f -- ${cur}) )
            return 0
            ;;
    esac

    if [[ ${cur} == -* ]] ; then
        COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
        return 0
    fi
}
complete -F _ugm_completions ugm.sh
complete -F _ugm_completions ./ugm.sh
EOF
            chmod 644 /etc/bash_completion.d/ugm
            echo -e "${GREEN}Bash completion installed to /etc/bash_completion.d/ugm${NC}"
            echo -e "${YELLOW}Please run 'source /etc/bash_completion.d/ugm' or open a new shell to use it.${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Error: Unknown flag or malformed input '${1}'${NC}" >&2
            echo "Run 'ugm.sh --help' for usage." >&2
            exit 1
            ;;
    esac
done

exit 0
